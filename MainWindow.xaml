<Window x:Class="maus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAUS"
        Height="750"
        Width="450"
        MinHeight="750"
        MinWidth="450"
        Icon="Images/maus.ico"
        Background="#1E1E1E">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Height"       Value="35"/>
            <Setter Property="MinHeight"    Value="35"/>
            <Setter Property="FontSize"     Value="15"/>
            <Setter Property="Background"   Value="#333333"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#555555"/>
            <Setter Property="Padding"      Value="8"/>
            <Setter Property="Margin"       Value="5"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Padding"    Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height"      Value="35"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Background"  Value="#333333"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Margin"      Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="10"
                                                      VerticalAlignment="Center"/>
                                    <ToggleButton Background="Transparent"
                                                  BorderThickness="0"
                                                  HorizontalAlignment="Right"
                                                  Width="30"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                              RelativeSource={RelativeSource TemplatedParent}}">
                                        <Path Data="M 0 0 L 6 6 L 12 0"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom">
                                <Border Background="#333333"
                                        BorderBrush="#555555"
                                        BorderThickness="1">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height"      Value="40"/>
            <Setter Property="MinWidth"    Value="120"/>
            <Setter Property="FontSize"    Value="16"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Background"  Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Margin"      Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <StackPanel Margin="18">
            <Border Background="#2B2B2B"
                    CornerRadius="10"
                    Padding="16">
                <StackPanel>

                    <TextBlock Text="Click Interval"
                               Foreground="White"
                               FontSize="18"/>

                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hours"        Foreground="White" Margin="5"/>
                            <TextBox Name="HoursIntervalBox"        Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Minutes"      Foreground="White" Margin="5"/>
                            <TextBox Name="MinutesIntervalBox"      Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Seconds"      Foreground="White" Margin="5"/>
                            <TextBox Name="SecondsIntervalBox"      Text="0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Milliseconds" Foreground="White" Margin="5"/>
                            <TextBox Name="MillisecondsIntervalBox" Text="1000"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Action"
           Foreground="White"
           FontSize="18"
           Margin="0,20,0,8"/>

                    <StackPanel>

                        <TextBlock Text="Action Type"
               Foreground="White"
               Margin="0,0,0,5"/>

                        <ComboBox Name="ActionTypeBox"
              SelectionChanged="ActionTypeBox_SelectionChanged">
                            <ComboBoxItem IsSelected="True">Mouse</ComboBoxItem>
                            <ComboBoxItem>Keyboard</ComboBoxItem>
                        </ComboBox>

                        <StackPanel Name="MousePanel">

                            <TextBlock Text="Mouse Button"
                   Foreground="White"
                   Margin="0,10,0,5"/>

                            <ComboBox Name="MouseButtonBox"/>

                            <TextBlock Text="Click Type"
                   Foreground="White"
                   Margin="0,10,0,5"/>

                            <ComboBox Name="ClickTypeBox"
                  SelectedIndex="0">
                                <ComboBoxItem>Single Click</ComboBoxItem>
                                <ComboBoxItem>Double Click</ComboBoxItem>
                            </ComboBox>

                        </StackPanel>

                        <StackPanel Name="KeyboardPanel"
                Visibility="Collapsed">

                            <TextBlock Text="Key"
                   Foreground="White"
                   Margin="0,10,0,5"/>

                            <TextBox Name="ActionKeyBox"
                 IsReadOnly="True"
                 Text="Press a key..."
                 PreviewMouseDown="ActionKeyBox_PreviewMouseDown"
                 PreviewKeyDown="ActionKeyBox_PreviewKeyDown"/>

                        </StackPanel>

                    </StackPanel>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Repeat"
                   Foreground="White"
                   FontSize="18"/>

                            <TextBlock Text="Click Count (-1 = ∞)"
                   Foreground="White"
                   Margin="0,6,0,5"/>

                            <TextBox Name="RepeatCountBox"
                 Text="-1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Hotkey"
                   Foreground="White"
                   FontSize="18"/>

                            <TextBlock Text="Toggle"
                   Foreground="White"
                   Margin="0,6,0,5"/>

                            <TextBox Name="HotkeyBox"
                 PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                        </StackPanel>

                    </Grid>

                    <Grid Margin="0,18,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
            Name="StartButton"
            Content="START"
            Margin="0,0,8,0"
            Click="StartButton_Click"/>

                        <Button Grid.Column="1"
            Name="StopButton"
            Content="STOP"
            Margin="8,0,0,0"
            Click="StopButton_Click"/>

                    </Grid>

                    <Border Background="#333333"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,20,0,0">
                        <TextBlock Name="StatusText"
                                   Text="Status: Stopped"
                                   Foreground="White"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </Border>
        </StackPanel>

        <TextBlock Name="VersionText"
                   Text="v1.0.0"
                   Foreground="Gray"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,15,10"/>

    </Grid>
</Window>
