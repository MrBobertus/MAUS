<Window x:Class="maus.MainWindow"
        PreviewKeyDown="Window_PreviewKeyDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MAUS"
        Height="600"
        Width="600">


    <Grid>

        <StackPanel Margin="20">


            <!-- Titel -->
            <TextBlock Text="MAUS"
                       FontSize="28"
                       Margin="0,0,0,20"/>



            <!-- Klickintervall -->

            <TextBlock Text="Klickintervall"
                       FontSize="16"/>


            <StackPanel Orientation="Horizontal"
                        Margin="0,5,0,20">


                <TextBox Name="HoursIntervalBox"
                         Text="0"
                         Width="70"
                         PreviewTextInput="IntervalBox_PreviewTextInput"/>


                <TextBox Name="MinutesIntervalBox"
                         Text="0"
                         Width="70"
                         Margin="10,0,0,0"
                         PreviewTextInput="IntervalBox_PreviewTextInput"/>


                <TextBox Name="SecondsIntervalBox"
                         Text="0"
                         Width="70"
                         Margin="10,0,0,0"
                         PreviewTextInput="IntervalBox_PreviewTextInput"/>


                <TextBox Name="MillisecondsIntervalBox"
                         Text="100"
                         Width="70"
                         Margin="10,0,0,0"
                         PreviewTextInput="IntervalBox_PreviewTextInput"/>

            </StackPanel>



            <!-- Klickart -->

            <TextBlock Text="Klickart"
                       FontSize="16"/>


            <ComboBox Name="MouseButtonBox"
                      SelectedIndex="0"
                      Margin="0,5,0,20">
            </ComboBox>



            <!-- Klickmodus -->


            <TextBlock Text="Klickmodus"
                       FontSize="16"/>


            <ComboBox Name="ClickTypeBox"
                      SelectedIndex="0"
                      Margin="0,5,0,20">


                <ComboBoxItem>
                    Einzelklick
                </ComboBoxItem>


                <ComboBoxItem>
                    Doppelklick
                </ComboBoxItem>


            </ComboBox>




            <!-- Hotkey -->


            <TextBlock Text="Start / Stop Hotkey"
                       FontSize="16"/>


            <TextBox Name="HotkeyBox"
                     Text="Hier Klicken"
                     Width="100"
                     HorizontalAlignment="Left"
                     Margin="0,5,0,20"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>




            <!-- Buttons -->


            <Button Name="StartButton"
                    Content="Start"
                    Height="35"
                    Click="StartButton_Click"
                    Margin="0,0,0,10"/>



            <Button Name="StopButton"
                    Content="Stop"
                    Height="35"
                    Click="StopButton_Click"/>




            <!-- Status -->


            <TextBlock Name="StatusText"
                       Text="Status: Gestoppt"
                       FontSize="16"
                       Margin="0,20,0,0"/>


        </StackPanel>


    </Grid>

</Window>